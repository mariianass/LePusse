<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" 
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" 
              name="ReporteClientesFrecuentes" 
              pageWidth="595" 
              pageHeight="842" 
              columnWidth="555" 
              leftMargin="20" 
              rightMargin="20" 
              topMargin="20" 
              bottomMargin="20" 
              uuid="d25b1a3c-1234-4321-b123-e4567890abcd">

    <parameter name="filtroNombre" class="java.lang.String"/>

    <field name="nombre" class="java.lang.String"/>
    <field name="apellidoPaterno" class="java.lang.String"/>
    <field name="telefono" class="java.lang.String"/>
    <field name="puntosFidelidad" class="java.lang.Integer"/>
    <field name="totalGastado" class="java.lang.Double"/>
    <field name="numeroVisitas" class="java.lang.Integer"/>
    <field name="fechaUltimaComanda" class="java.time.LocalDate"/>

    <pageHeader>
        <band height="100" splitType="Stretch">
            <staticText>
                <reportElement x="0" y="10" width="555" height="30" forecolor="#3D2B1F" uuid="a1234567-b123-c123-d123-e12345678901"/>
                <textElement textAlignment="Left" verticalAlignment="Middle">
                    <font size="22" isBold="true"/>
                </textElement>
                <text><![CDATA[Reporte de Clientes]]></text>
            </staticText>

            <textField>
                <reportElement x="0" y="45" width="555" height="20" forecolor="#4B3621" uuid="b1234567-c123-d123-e123-f12345678902"/>
                <textElement textAlignment="Left">
                    <font size="11" isItalic="false"/>
                </textElement>
                <textFieldExpression><![CDATA["Filtro aplicado: " + ($P{filtroNombre} != null ? $P{filtroNombre} : "Todos")]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="0" y="65" width="555" height="15" forecolor="#C5B38A" uuid="c1234567-d123-e123-f123-012345678903"/>
                <textElement textAlignment="Left">
                    <font size="9" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Generado el: " + new java.text.SimpleDateFormat("dd/MM/yyyy HH:mm").format(new java.util.Date())]]></textFieldExpression>
            </textField>
            
            <line>
                <reportElement x="0" y="85" width="555" height="1" forecolor="#E6DACE" />
                <graphicElement><pen lineWidth="2.0"/></graphicElement>
            </line>
        </band>
    </pageHeader>

    <columnHeader>
        <band height="25" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="0" width="555" height="22" backcolor="#4B3621" uuid="e1234567-f123-0123-1123-212345678905"/>
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <staticText>
                <reportElement x="5" y="0" width="155" height="20" forecolor="#FFFFFF" uuid="f1234567-0123-1123-2123-312345678906"/>
                <textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[CLIENTE]]></text>
            </staticText>
            <staticText>
                <reportElement x="165" y="0" width="80" height="20" forecolor="#FFFFFF" uuid="01234567-1123-2123-3123-412345678907"/>
                <textElement verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[TELÉFONO]]></text>
            </staticText>
            <staticText>
                <reportElement x="250" y="0" width="50" height="20" forecolor="#FFFFFF" uuid="11234567-2123-3123-4123-512345678908"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[VISITAS]]></text>
            </staticText>
            <staticText>
                <reportElement x="305" y="0" width="60" height="20" forecolor="#FFFFFF" uuid="21234567-3123-4123-5123-612345678909"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[PUNTOS]]></text>
            </staticText>
            <staticText>
                <reportElement x="370" y="0" width="90" height="20" forecolor="#FFFFFF" uuid="31234567-4123-5123-6123-712345678910"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[ÚLT. COMPRA]]></text>
            </staticText>
            <staticText>
                <reportElement x="465" y="0" width="85" height="20" forecolor="#FFFFFF" uuid="41234567-5123-6123-7123-812345678911"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[TOTAL]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="25" splitType="Stretch">
            <textField>
                <reportElement x="5" y="0" width="155" height="20" forecolor="#3D2B1F" uuid="51234567-6123-7123-8123-912345678912"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{nombre} + " " + $F{apellidoPaterno}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="165" y="0" width="80" height="20" forecolor="#3D2B1F" uuid="61234567-7123-8123-9123-012345678913"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{telefono}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="250" y="0" width="50" height="20" forecolor="#3D2B1F" uuid="71234567-8123-9123-0123-112345678914"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{numeroVisitas} != null ? $F{numeroVisitas} : 0]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="305" y="0" width="60" height="20" forecolor="#3D2B1F" uuid="81234567-9123-0123-1123-212345678915"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{puntosFidelidad} != null ? $F{puntosFidelidad} : 0]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="370" y="0" width="90" height="20" forecolor="#3D2B1F" uuid="92345678-1234-1234-1234-567890abcdef"/>
                <textElement textAlignment="Center" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{fechaUltimaComanda} != null ? 
                    $F{fechaUltimaComanda}.format(java.time.format.DateTimeFormatter.ofPattern("dd/MM/yyyy")) : 
                    "-"]]></textFieldExpression>
            </textField>
            <textField pattern="$ #,##0.00">
                <reportElement x="465" y="0" width="85" height="20" forecolor="#3D2B1F" uuid="01234567-1123-2123-3123-412345678917"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"/>
                <textFieldExpression><![CDATA[$F{totalGastado} != null ? $F{totalGastado} : 0.0]]></textFieldExpression>
            </textField>
            <line>
                <reportElement x="0" y="22" width="555" height="1" forecolor="#E6DACE" uuid="11234567-2123-3123-4123-512345678918"/>
            </line>
        </band>
    </detail>

    <summary>
        <band height="45" splitType="Stretch">
            <rectangle>
                <reportElement x="0" y="10" width="555" height="25" backcolor="#E6DACE" />
                <graphicElement><pen lineWidth="0.0"/></graphicElement>
            </rectangle>
            <textField>
                <reportElement x="0" y="10" width="555" height="25" forecolor="#4B3621" uuid="21234567-3123-4123-5123-612345678919"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true" isItalic="false"/>
                </textElement>
                <textFieldExpression><![CDATA["Total de Clientes en este reporte: " + $V{REPORT_COUNT}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>